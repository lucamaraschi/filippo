{
  "name": "@menubar/cli",
  "version": "0.1.0",
  "description": "Declarative menu bar icon manager for macOS — CLI & TUI",
  "type": "module",
  "license": "MIT",
  "bin": {
    "menubar": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin"
  ],
  "keywords": [
    "macos",
    "menu-bar",
    "hidden-bar",
    "bartender",
    "status-bar",
    "tui",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "",
    "directory": "packages/cli"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "ink": "^5.1.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
